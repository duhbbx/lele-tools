# Example environment configuration file
# Copy this file to .env.{ENVIRONMENT} (e.g., .env.台式机, .env.laptop, .env.docker)
# and customize the paths for your system

# === Redis Configuration ===
# Redis Plus Plus library paths
REDIS_PLUS_PLUS_INCLUDE_DIR=D:/projects/vcpkg/installed/x64-windows/include
REDIS_PLUS_PLUS_LIBRARY=D:/projects/vcpkg/installed/x64-windows/lib/redis++.lib
HIREDIS_LIBRARY=D:/projects/vcpkg/installed/x64-windows/lib/hiredis.lib

# === MySQL Configuration ===
# MySQL library paths
MYSQL_INCLUDE_DIR=D:/projects/vcpkg/installed/x64-windows/include/mysql
MYSQL_LIBRARY=D:/projects/vcpkg/installed/x64-windows/lib/libmysql.lib

# Alternative: MySQL installation root
# MYSQL_ROOT_DIR=C:/Program Files/MySQL/MySQL Server 8.0

# === Npcap/Pcap Configuration ===
# Npcap SDK paths (Windows)
PCAP_INCLUDE_DIR=C:/npcap-sdk-1.15/Include
PCAP_LIBRARY=C:/npcap-sdk-1.15/Lib/x64/wpcap.lib
PACKET_LIBRARY=C:/npcap-sdk-1.15/Lib/x64/packet.lib

# Alternative: Set SDK root
# NPCAP_SDK_PATH=C:/npcap-sdk-1.15

# === OpenCV Configuration ===
# OpenCV installation path
OpenCV_DIR=C:/opencv/build

# === Qt Configuration (if custom installation) ===
# Qt_DIR=C:/Qt/6.9.1/msvc2022_64

# === Build Configuration ===
# Enable/disable features
# WITH_OPENCV=ON
# WITH_MYSQL=ON
# WITH_PCAP=ON
# ENABLE_REDIS=ON
# WITH_QT_MULTIMEDIA=ON

# === Compiler Settings ===
# CMAKE_BUILD_TYPE=Debug
# CMAKE_CXX_STANDARD=20

# === Custom paths ===
# Add any custom library or tool paths here
# CUSTOM_TOOL_PATH=/path/to/custom/tool